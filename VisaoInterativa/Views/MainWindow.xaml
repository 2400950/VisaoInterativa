<Window x:Class="VisaoInterativa.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VisãoInterativa" Height="300" Width="400">
    <StackPanel Margin="10">
        <TextBlock Text="Aplicação de controlo por gestos" FontSize="16" Margin="0,0,0,10"/>
        <Button x:Name="btnIniciar" Content="Iniciar Captura" Margin="0,5" Click="BtnIniciar_Click"/>
        <Button x:Name="btnParar" Content="Parar Captura" Margin="0,5" Click="BtnParar_Click"/>
        <TextBlock x:Name="tbFeedback" Text="Pronto para iniciar..." Margin="0,10" FontWeight="Bold"/>
        <TextBlock x:Name="tbEstado" Text="Parado" Margin="0,5"/>
    </StackPanel>
</Window>